{
  "name": "@kenn-io/kit-ui",
  "version": "0.0.1",
  "license": "Apache-2.0",
  "type": "module",
  "main": "src/lib/index.ts",
  "types": "src/lib/index.ts",
  "svelte": "src/lib/index.ts",
  "exports": {
    ".": {
      "svelte": "./src/lib/index.ts",
      "default": "./src/lib/index.ts"
    },
    "./theme.css": "./src/lib/theme.css",
    "./breakpoints": {
      "default": "./src/lib/breakpoints.ts"
    },
    "./check/rules": {
      "default": "./checks/rules.mjs"
    },
    "./utils/clipboard": {
      "default": "./src/lib/utils/clipboard.ts"
    },
    "./utils/color-hash": {
      "default": "./src/lib/utils/color-hash.ts"
    },
    "./utils/debounce": {
      "default": "./src/lib/utils/debounce.ts"
    },
    "./utils/focus-trap": {
      "default": "./src/lib/utils/focus-trap.ts"
    },
    "./utils/format": {
      "default": "./src/lib/utils/format.ts"
    },
    "./utils/markdown": {
      "default": "./src/lib/utils/markdown.ts"
    },
    "./utils/overlay": {
      "default": "./src/lib/utils/overlay.ts"
    },
    "./utils/popover": {
      "default": "./src/lib/utils/popover.ts"
    },
    "./utils/refresh": {
      "default": "./src/lib/utils/refresh.ts"
    },
    "./utils/shortcuts": {
      "default": "./src/lib/utils/shortcuts.ts"
    },
    "./utils/time": {
      "default": "./src/lib/utils/time.ts"
    }
  },
  "bin": {
    "kit-ui-check": "./bin/kit-ui-check.mjs"
  },
  "files": [
    "src/lib",
    "bin",
    "checks/rules.mjs"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:usage": "node bin/kit-ui-check.mjs src/demo",
    "fmt": "vp fmt -c .oxfmtrc.json . '!dist/**' '!test-results/**' --no-error-on-unmatched-pattern",
    "fmt:check": "vp fmt --check -c .oxfmtrc.json . '!dist/**' '!test-results/**' --no-error-on-unmatched-pattern",
    "lint": "vp lint . --no-error-on-unmatched-pattern",
    "test": "bun test checks/",
    "test:browser": "playwright test",
    "svelte-mcp": "svelte-mcp"
  },
  "devDependencies": {
    "@lucide/svelte": "1.21.0",
    "@playwright/test": "^1.61.1",
    "@sveltejs/mcp": "0.1.24",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tsconfig/svelte": "5.0.8",
    "@types/node": "^26.0.0",
    "svelte": "5.56.3",
    "svelte-check": "4.6.0",
    "typescript": "^5.9.0",
    "vite": "8.0.16",
    "vite-plus": "0.2.1"
  },
  "peerDependencies": {
    "@lucide/svelte": ">=1.0.0",
    "dompurify": "^3.2.0",
    "marked": "^18.0.0",
    "shiki": "^4.0.0",
    "svelte": "^5.29.0"
  },
  "packageManager": "bun@1.3.14"
}
